# Supabase — used by both admin and public apps
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_ANON_KEY=eyJ...

# Database (migrations only — used by drizzle-kit / packages/db)
DATABASE_URL=postgres://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Daily digest (apps/admin) — see ops/launch/pre-launch-checklist.md
# CRON_SECRET protects /api/cron/digest. Vercel Cron sends it as a Bearer token.
CRON_SECRET=change-me-long-random-string
# Resend API key — https://resend.com (transactional email provider for the digest)
RESEND_API_KEY=re_...
# Comma-separated recipient list for the digest email
DIGEST_TO_EMAIL=patrick@example.com
# Verified sender (defaults to digest@nulldiary.io if unset)
DIGEST_FROM_EMAIL=digest@nulldiary.io
# Public URL of the admin app, used to build "Pending: N" link in the digest
ADMIN_PUBLIC_URL=https://admin.nulldiary.io
